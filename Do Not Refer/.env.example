# Copy to apps/api/.env and packages/db/.env, fill in real values. Never commit .env.

# packages/db + apps/api
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expense_reimbursement?schema=public"

# apps/api
PORT=4000
JWT_ACCESS_SECRET="change-me"
JWT_REFRESH_SECRET="change-me-too"
ACCESS_TOKEN_TTL_MIN=15
SESSION_IDLE_TIMEOUT_MIN=20
MFA_ISSUER="ExpenseRMS"

# apps/web
VITE_API_BASE_URL="http://localhost:4000/api"
